# Tether Backend Configuration
DATABASE_URL=sqlite+aiosqlite:///./tether.db
REDIS_URL=redis://localhost:6379/0
# Required in every environment. Generate a unique value with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
WEATHER_API_KEY=
CORS_ORIGINS=http://localhost:3000,http://localhost:19006,http://127.0.0.1:3000,http://127.0.0.1:19006
ALLOW_ANONYMOUS_WS=false
