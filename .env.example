# Tether local development configuration
ENVIRONMENT=development
DATABASE_URL=sqlite+aiosqlite:///./tether.db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=replace-with-a-long-random-value-before-deployment
CORS_ORIGINS=http://localhost:3000,http://localhost:19006,http://127.0.0.1:3000,http://127.0.0.1:19006
ALLOW_ANONYMOUS_WS=false
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
WS_TICKET_EXPIRE_SECONDS=60
LOCATION_CELL_DEGREES=0.1
LOCATION_TTL_SECONDS=900
PULSE_COOLDOWN_SECONDS=3
TELEMETRY_ENABLED=true
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
OPENWEATHER_API_KEY=
AD_SSV_SECRET=
